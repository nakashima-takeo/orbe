{
  "$meta": {
    "name": "Orbe design system tokens",
    "version": "0.4.0",
    "direction": "Orbe デザインシステム (思想・契約は docs/design-system.md が正)",
    "appearances": ["dark", "light"],
    "note": "値の正は Sources/Orbe/DesignSystem/DesignTokens.swift。本ファイルは機械可読ミラー。dark=温かい炭＋フロストガラス / light=藤紙。色は状態(確定配色の温度分け)と自分の出番(電紫 accent)に。ガラス質感・elevation・glow は DesignTokens+Glass.swift 所有。複数名が同値へ意図的に収束する。state.*Inverse は対テーマの状態色（選択タブの反転面用・dark/light を入れ替えた値）。"
  },
  "color": {
    "bg.base":        { "dark": "#1a1721", "light": "#fcfbfe", "use": "不透明ベース" },
    "bg.sunken":      { "dark": "rgba(255,255,255,0.03)", "light": "rgba(58,49,81,0.05)", "use": "行地・gutter・淡い面" },
    "bg.deepest":     { "dark": "rgba(255,255,255,0.04)", "light": "rgba(58,49,81,0.04)", "use": "最深・トグル溝" },
    "surface.0":      { "dark": "rgba(255,255,255,0.03)", "light": "rgba(58,49,81,0.05)", "use": "面(bg.sunken へ収束)" },
    "surface.1":      { "dark": "rgba(255,220,180,0.08)", "light": "rgba(110,90,170,0.12)", "use": "罫線・secondary 枠" },
    "surface.2":      { "dark": "rgba(255,220,180,0.10)", "light": "rgba(110,90,170,0.15)", "use": "面(強)・強枠" },
    "text.primary":   { "dark": "#eaddc7", "light": "#3a3151", "use": "本文・選択ラベル・タブ反転面の地" },
    "text.secondary": { "dark": "#b8afc4", "light": "#5f5678", "use": "通常ラベル・非選択タブ文字" },
    "text.tertiary":  { "dark": "#8b8397", "light": "#8d85a3", "use": "三次(muted へ収束)" },
    "text.muted":     { "dark": "#8b8397", "light": "#8d85a3", "use": "非アクティブ・補助・ヒント" },
    "accent.primary": { "dark": "#9068f0", "light": "#6d43d8", "use": "選択・自分の出番・プロンプト" },
    "accent.focus":   { "dark": "#9068f0", "light": "#6d43d8", "use": "フォーカス(accent.primary へ収束)" },
    "on.accent":      { "dark": "#1a1721", "light": "#fcfbfe", "use": "accent 塗り上のインク=地色" },
    "diff.added":     { "dark": "#81b88b", "light": "#279a4d", "use": "追加(green)" },
    "diff.removed":   { "dark": "#d16969", "light": "#e02d33", "use": "削除(red)" },
    "success":        { "dark": "#81b88b", "light": "#279a4d", "use": "成功(green・diff.added へ収束)" },
    "danger":         { "dark": "#d16969", "light": "#e02d33", "use": "エラー(red・diff.removed へ収束)" },
    "conflict":       { "dark": "#e2cd6d", "light": "#b17b00", "use": "競合=注意色(黄・ANSI黄)" },
    "state.working":  { "dark": "#85adff", "light": "#1f66c9", "use": "working（青・accent と分離）" },
    "state.waiting":  { "dark": "#eec25a", "light": "#b17b00", "use": "要応答(黄・conflict とは別値)" },
    "state.done":     { "dark": "#82d894", "light": "#279a4d", "use": "完了(緑・diff.added とは別値)" },
    "state.idle":     { "dark": "#8a82b8", "light": "#8b82a8" },
    "state.dormant":  { "dark": "#8b8397", "light": "#8d85a3", "use": "muted へ収束" },
    "state.workingInverse": { "dark": "#1f66c9", "light": "#85adff", "use": "反転面上の working（対テーマ色）" },
    "state.waitingInverse": { "dark": "#b17b00", "light": "#eec25a", "use": "反転面上の waiting（対テーマ色）" },
    "state.doneInverse":    { "dark": "#279a4d", "light": "#82d894", "use": "反転面上の done（対テーマ色）" },
    "statusText":     { "dark": "#cad3f5", "light": "#4d4368", "use": "ステータスストリップの件数" },
    "stripDivider":   { "dark": "rgba(255,255,255,0.12)", "light": "rgba(58,49,81,0.16)", "use": "ストリップの区切り線" },
    "checkStroke":    { "dark": "#0a0a0a", "light": "#f3f0fa", "use": "done グリフの check 線" },
    "tab.rowBg":      { "dark": "rgba(0,0,0,0.28)", "light": "rgba(58,49,81,0.08)", "use": "タブ行全幅の地" },
    "tab.segBg":      { "dark": "rgba(255,255,255,0.10)", "light": "rgba(58,49,81,0.06)", "use": "非選択セグメントの地" },
    "tab.activeText": { "dark": "#1a1721", "light": "#f3f0fa", "use": "選択セグメント(反転面)の文字。light は bg.base と別値" },
    "smallPillFill":  { "dark": "rgba(255,255,255,0.04)", "light": "rgba(58,49,81,0.06)", "use": "キーヒント・小ピル地" },
    "tint.working":   { "dark": "rgba(133,173,255,0.12)", "light": "rgba(31,102,201,0.12)", "use": "working 件数ピル（per-theme）" },
    "tint.waiting":   { "dark": "rgba(238,194,90,0.12)", "light": "rgba(177,123,0,0.12)" },
    "tint.done":      { "dark": "rgba(130,216,148,0.12)", "light": "rgba(39,154,77,0.12)" },
    "tint.red":       { "dark": "rgba(209,105,105,0.14)", "light": "rgba(224,45,51,0.14)" },
    "scrim":          { "dark": "rgba(10,8,14,0.35)", "light": "rgba(58,49,81,0.18)", "use": "通常オーバーレイ暗幕" },
    "scrimStrong":    { "dark": "rgba(10,8,14,0.40)", "light": "rgba(58,49,81,0.22)", "use": "強いオーバーレイ暗幕" },
    "surfaceInk":     { "dark": "#ffffff", "light": "#3a3151", "use": "EditorPane の面/罫線の基色（view 側で opacity を掛ける）" },
    "borderInk":      { "dark": "#ffdcb4", "light": "#6e5aaa", "use": "EditorPane の枠線の基色（view 側で opacity を掛ける）" },
    "paneWash":       { "dark": "rgba(10,8,14,0.14)", "light": "rgba(58,49,81,0.05)", "use": "EditorPane の地（暗幕基調の淡い被せ）" },
    "inputWash":      { "dark": "rgba(10,8,14,0.25)", "light": "rgba(58,49,81,0.06)", "use": "入力欄の地（暗幕基調の淡い被せ）" },
    "inputBorder":    { "dark": "rgba(255,220,180,0.12)", "light": "rgba(110,90,170,0.16)", "use": "入力欄の枠（borderInk 基調・surface1 より濃い）" },
    "createDashBorder": { "dark": "rgba(255,220,180,0.18)", "light": "rgba(110,90,170,0.28)", "use": "作成導線行の破線罫線（borderInk 基調）" },
    "tint.accent":    { "dark": "rgba(144,104,240,0.12)", "light": "rgba(109,67,216,0.12)", "use": "accent 12% の淡塗り（ブランチチップ）" },
    "promptGreen":    { "dark": "#81b88b", "light": "#279a4d", "use": "プロンプト・コマンド行（diff.added へ収束）" }
  },
  "fill": {
    "selection": { "color": "accent.primary", "alpha": { "dark": 0.14, "light": 0.14 } },
    "diffSelection": { "color": "accent.primary", "alpha": { "dark": 0.10, "light": 0.10 } },
    "hover":     { "color": "accent.primary", "alpha": { "dark": 0.10, "light": 0.10 } }
  },
  "opacity": {
    "dormant": 0.45,
    "disabled": 0.45,
    "pressed": 0.85
  },
  "type": {
    "title":        { "size": 14,   "weight": "regular",  "family": "monospaced" },
    "label":        { "size": 12.5, "weight": "medium",   "family": "monospaced" },
    "labelStrong":  { "size": 12.5, "weight": "semibold", "family": "monospaced" },
    "body":         { "size": 12.5, "weight": "regular",  "family": "system" },
    "code":         { "size": 12.5, "weight": "regular",  "family": "monospaced" },
    "chrome":       { "size": 11,   "weight": "regular",  "family": "monospaced" },
    "workspaceName":{ "size": 12,   "weight": "regular",  "family": "monospaced" },
    "diffHeader":   { "size": 12,   "weight": "regular",  "family": "monospaced" },
    "diffStat":     { "size": 11,   "weight": "regular",  "family": "monospaced", "digits": "monospaced" },
    "codeSmall":    { "size": 11,   "weight": "regular",  "family": "monospaced" },
    "codeCompact":  { "size": 11.5, "weight": "regular",  "family": "monospaced" },
    "bodySmall":    { "size": 10.5, "weight": "regular",  "family": "system" },
    "caption":      { "size": 11,   "weight": "medium",   "family": "monospaced" },
    "captionDigit": { "size": 11,   "weight": "medium",   "family": "monospaced", "digits": "monospaced" },
    "meta":         { "size": 10,   "weight": "regular",  "family": "monospaced" },
    "sectionLabel": { "size": 9.5,  "weight": "regular",  "family": "monospaced", "case": "upper" },
    "display":      { "size": 26,   "weight": "regular",  "family": "system" },
    "paneRow":      { "size": 10.5, "weight": "regular",  "family": "monospaced", "use": "EditorPane レール行・本文行" },
    "paneControl":  { "size": 10,   "weight": "regular",  "family": "monospaced", "use": "EditorPane ヘッダ・ボタン・入力・履歴タイトル" },
    "paneAnnotation": { "size": 9.5, "weight": "regular", "family": "monospaced", "use": "EditorPane ↑↓・hunk ヘッダ・注記" },
    "paneSegment":  { "size": 9,    "weight": "regular",  "family": "monospaced", "use": "EditorPane セグメント・小ボタン・集計" },
    "paneFootnote": { "size": 8.5,  "weight": "regular",  "family": "monospaced", "use": "EditorPane フッタ・stat・履歴サブ" },
    "paneBadge":    { "size": 8,    "weight": "regular",  "family": "monospaced", "use": "EditorPane CommitDetail のファイルバッジ" },
    "paneTag":      { "size": 7.5,  "weight": "regular",  "family": "monospaced", "use": "EditorPane HEAD/ref/tag バッジ" },
    "proseBody":    { "size": 11.5, "weight": "regular",  "family": "system", "use": "EditorPane md プレビュー本文" },
    "proseHeading": { "size": 13,   "weight": "semibold", "family": "system", "use": "EditorPane md プレビュー H2+" },
    "proseTitle":   { "size": 17,   "weight": "bold",     "family": "system", "use": "EditorPane md プレビュー H1" },
    "tracking":     { "label": 1, "status": 0.3 },
    "lineHeight":   { "body": 1.6, "terminal": 1.55, "pane": 1.7 }
  },
  "space": { "hair": 2, "tick": 4, "note": 6, "step": 8, "beat": 12, "bar": 16, "span": 20, "phrase": 24 },
  "radius": { "xs": 3, "sm": 4, "row": 8, "md": 10, "card": 12, "lg": 16, "pill": 999 },
  "stroke": { "hairline": 1, "marker": 3, "focusRing": 2 },
  "motion": {
    "instant": 0,
    "quick": 0.12,
    "base": 0.18,
    "slow": 0.24,
    "easing": "cubic-bezier(0.2, 0, 0, 1)",
    "spin": 1.6,
    "float": 2.6,
    "floatOffset": -1,
    "blink": 1.1
  }
}
